---
import acuity from '../data/acuity.json';

interface Props {
  /** Load iframe immediately — use on /book */
  eager?: boolean;
}

const { eager = false } = Astro.props;

const acuitySrc = `https://app.acuityscheduling.com/schedule.php?owner=${acuity.ownerId}&ref=${acuity.ref}`;
---

<div class="acuity-embed bg-white border border-gray-200 rounded-sm overflow-hidden">
  <iframe
    src={acuitySrc}
    title={acuity.title}
    width="100%"
    height={acuity.iframeHeight}
    loading={eager ? 'eager' : 'lazy'}
    allow="payment *"
    referrerpolicy="no-referrer-when-downgrade"
    class="w-full min-h-[600px] sm:min-h-[800px] border-0"
  ></iframe>
  <p class="text-xs text-center text-gray-500 py-3 px-4 border-t border-gray-100">
    Having trouble with the calendar?
    <a href={acuity.directUrl} target="_blank" rel="noopener noreferrer" class="hover:underline">Open scheduler in a new tab</a>
    or call <a href="tel:3478563025" class="hover:underline">(347) 856-3025</a>
  </p>
</div>
