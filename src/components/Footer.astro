---
import { EMAIL, PHONE, PHONE_TEL } from '../lib/site';
---

<footer id="contact" class="border-t border-gray-200 py-12 md:py-14 text-sm text-gray-600">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center md:text-left md:grid md:grid-cols-3 md:gap-8">
      <div>
        <p class="font-bold text-[#1a1a1a] tracking-[0.15em] text-xs uppercase">JOSE DOES IT! LLC</p>
        <p class="mt-3">
          <a href="https://www.instagram.com/josejosejosedoesit" target="_blank" rel="noopener noreferrer" class="hover:underline">Instagram</a>
          <span class="mx-2">·</span>
          <a href="https://www.tiktok.com/@josejosejosedoesit" target="_blank" rel="noopener noreferrer" class="hover:underline">TikTok</a>
        </p>
      </div>
      <div class="mt-6 md:mt-0">
        <p class="font-semibold text-xs uppercase tracking-wider text-gray-800 mb-2">Contact</p>
        <p>
          <a href={PHONE_TEL} class="hover:underline">{PHONE}</a>
        </p>
        <p class="mt-1">
          <a href={`mailto:${EMAIL}`} class="hover:underline break-all">{EMAIL}</a>
        </p>
      </div>
      <div class="mt-6 md:mt-0 md:text-right">
        <p class="font-semibold text-xs uppercase tracking-wider text-gray-800 mb-2">Service Area</p>
        <p class="text-xs leading-relaxed text-gray-500">
          Brooklyn · Queens · Long Island
        </p>
        <p class="mt-3">
          <a href="/book" class="text-xs uppercase tracking-wider hover:underline">Book Online →</a>
        </p>
      </div>
    </div>
  </div>
</footer>
