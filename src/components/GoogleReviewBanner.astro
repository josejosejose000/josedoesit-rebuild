---
import googleReviews from '../data/google-reviews.json';

const { enabled, rating, reviewCount, url, headline, cta } = googleReviews;

if (!enabled || !url) {
  return null;
}

const halfStarId = `half-star-${Math.random().toString(36).slice(2, 9)}`;
const fullStars = Math.floor(rating);
const hasHalfStar = rating - fullStars >= 0.25 && rating - fullStars < 0.75;
const extraFullFromHalf = rating - fullStars >= 0.75 ? 1 : 0;
const totalFull = Math.min(5, fullStars + extraFullFromHalf);
const showHalf = hasHalfStar && totalFull < 5;
const emptyStars = 5 - totalFull - (showHalf ? 1 : 0);

const ratingLabel = rating.toFixed(1);
const countLabel =
  typeof reviewCount === 'number' && reviewCount > 0
    ? `${reviewCount.toLocaleString()} Google review${reviewCount === 1 ? '' : 's'}`
    : 'Google reviews';
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="google-review-banner"
  aria-label={`${ratingLabel} out of 5 on Google — ${cta}`}
>
  <span class="google-review-banner__inner">
    <span class="google-review-banner__brand" aria-hidden="true">
      <svg class="google-review-banner__logo" viewBox="0 0 24 24" width="20" height="20">
        <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
        <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
        <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
        <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
      </svg>
      <span class="google-review-banner__google-text">Google</span>
    </span>

    <span class="google-review-banner__rating">
      <span class="google-review-banner__score">{ratingLabel}</span>
      <span class="google-review-banner__stars" aria-hidden="true">
        {Array.from({ length: totalFull }).map(() => (
          <svg class="google-review-banner__star google-review-banner__star--full" viewBox="0 0 20 20" width="16" height="16">
            <path fill="currentColor" d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.5L10 14.2l-4.94 2.51.94-5.5-4-3.9 5.53-.8L10 1.5z"/>
          </svg>
        ))}
        {showHalf && (
          <svg class="google-review-banner__star google-review-banner__star--half" viewBox="0 0 20 20" width="16" height="16">
            <defs>
              <linearGradient id={halfStarId}>
                <stop offset="50%" stop-color="currentColor"/>
                <stop offset="50%" stop-color="#d1d5db"/>
              </linearGradient>
            </defs>
            <path fill={`url(#${halfStarId})`} d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.5L10 14.2l-4.94 2.51.94-5.5-4-3.9 5.53-.8L10 1.5z"/>
          </svg>
        )}
        {Array.from({ length: emptyStars }).map(() => (
          <svg class="google-review-banner__star google-review-banner__star--empty" viewBox="0 0 20 20" width="16" height="16">
            <path fill="currentColor" d="M10 1.5l2.47 5.01 5.53.8-4 3.9.94 5.5L10 14.2l-4.94 2.51.94-5.5-4-3.9 5.53-.8L10 1.5z"/>
          </svg>
        ))}
      </span>
    </span>

    <span class="google-review-banner__copy">
      <span class="google-review-banner__headline">{headline}</span>
      <span class="google-review-banner__meta">{countLabel}</span>
    </span>

    <span class="google-review-banner__cta">{cta} →</span>
  </span>
</a>
