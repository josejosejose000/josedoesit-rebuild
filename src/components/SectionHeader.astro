---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  centered?: boolean;
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  centered = true,
  class: className = '',
} = Astro.props;
---

<header class:list={[centered && 'text-center', className]}>
  {eyebrow && (
    <p class="text-xs uppercase tracking-[0.25em] text-gray-500 mb-3">{eyebrow}</p>
  )}
  <h2 class="text-lg md:text-xl font-semibold max-w-2xl mx-auto">{title}</h2>
  {description && (
    <p class="mt-3 text-sm text-gray-600 max-w-lg mx-auto leading-relaxed">{description}</p>
  )}
</header>
